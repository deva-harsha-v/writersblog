    <!-- SECTION 3 — CHARACTERS SECTION -->
    <section id="characters" class="characters-section section-offset">
        <div class="container">
            <span class="section-label">The Cast</span>
            <h2 class="section-heading">People Carried by Fate</h2>
            <div class="characters-grid">
                <div class="character-card">
                    <div class="char-header">
                        <h3 class="char-name">Rohit Sharma</h3>
                        <span class="char-role">Protagonist</span>
                    </div>
                    <p class="char-desc">A young engineering student with a historical curse of falling in love at first sight with simple kindness. When faced with a deep, forbidden love, he transforms from an impulsive pursuer into a deeply focused, quiet protector willing to wait forever.</p>
                    <div class="traits-container">
                        <span class="trait-tag">Patient</span>
                        <span class="trait-tag">Empathetic</span>
                        <span class="trait-tag">Disciplined</span>
                    </div>
                </div>
                <div class="character-card">
                    <div class="char-header">
                        <h3 class="char-name">Saanvi</h3>
                        <span class="char-role">The Steady Note</span>
                    </div>
                    <p class="char-desc">Meera's best friend. Self-contained, traditional, and bound by her family's strict social rules. She communicates through delicate, intentional micro-actions, harboring a profound affection that she is initially too terrified to voice aloud.</p>
                    <div class="traits-container">
                        <span class="trait-tag">Quiet</span>
                        <span class="trait-tag">Resilient</span>
                        <span class="trait-tag">Thoughtful</span>
                    </div>
                </div>
                <div class="character-card">
                    <div class="char-header">
                        <h3 class="char-name">Meera</h3>
                        <span class="char-role">The Anchor</span>
                    </div>
                    <p class="char-desc">Rohit's college sister and Saanvi's lifelong best friend. She serves as the structural bridge, translating their heavy silences, guarding their secrets, and pushing Rohit to act when opportunities arise.</p>
                    <div class="traits-container">
                        <span class="trait-tag">Loyal</span>
                        <span class="trait-tag">Perceptive</span>
                        <span class="trait-tag">Protective</span>
                    </div>
                </div>
                <div class="character-card">
                    <div class="char-header">
                        <h3 class="char-name">Saanvi's Father</h3>
                        <span class="char-role">The Guardian</span>
                    </div>
                    <p class="char-desc">A polite but deeply principled, traditional man who views community boundaries as absolute shields for his family's reputation. He values established social stability over romance.</p>
                    <div class="traits-container">
                        <span class="trait-tag">Rigid</span>
                        <span class="trait-tag">Polite</span>
                        <span class="trait-tag">Traditional</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 4 — CHAPTERS SECTION -->
    <section id="chapters" class="chapters-section section-offset">
        <div class="container">
            <span class="section-label">The Structure</span>
            <h2 class="section-heading">A Narrative of Quiet Years</h2>
            <div class="chapters-grid">
                <div class="chapter-card">
                    <span class="chap-num">Chapter 1</span>
                    <h3 class="chap-title">The Guy Who Fell Too Fast</h3>
                    <p class="chap-teaser">Explore Rohit's notorious history of early, idealistic infatuations at Sri Varma College and his shifting ideals before destiny walks in.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 2</span>
                    <h3 class="chap-title">The Best Friend's Secret</h3>
                    <p class="chap-teaser">Saanvi slips into Rohit's life on a humid Tuesday afternoon, initiating a delicate grammar of wordless presence and domestic proximity.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 3</span>
                    <h3 class="chap-title">Promises & Premonitions</h3>
                    <p class="chap-teaser">Under rain-dark clouds at the local tea stall, a micro-interaction of shared space proves the unsaid elements are louder than ever.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 4</span>
                    <h3 class="chap-title">The Weight of Waiting</h3>
                    <p class="chap-teaser">As campus whispers intensify, a subtle fracture occurs when familial shadows encroach upon their silent library sanctuary.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 5</span>
                    <h3 class="chap-title">The First Storm</h3>
                    <p class="chap-teaser">Rohit encounters harsh gossip across canteen tables, causing Saanvi to weep in secret and inspiring an internal transformation.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 6</span>
                    <h3 class="chap-title">The Silent Season</h3>
                    <p class="chap-teaser">Midst upcoming semester exams, small pieces of lunch and borrowed notes serve as an unshakable, quiet confession.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 7</span>
                    <h3 class="chap-title">The Birthday Revelation</h3>
                    <p class="chap-teaser">A sobering conversation under the birthday stars reveals the betrayal of loose friends and sharpens Rohit's singular ultimate choice.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 8</span>
                    <h3 class="chap-title">The Girl Who Knew But Never Said</h3>
                    <p class="chap-teaser">Shifting to Saanvi's inner voice, she explores the deep, insurmountable walls built from tradition and her quiet prayer for his knowledge.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 9</span>
                    <h3 class="chap-title">Last Days Before Goodbye</h3>
                    <p class="chap-teaser">The terminal semester brings placement drives and frantic packing, rendering ordinary partings heavy with permanent weight.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 10</span>
                    <h3 class="chap-title">After the Last Bell</h3>
                    <p class="chap-teaser">Graduation day passes devoid of cinematic fanfare, leading into sudden, staggering warnings regarding an arranged caste match.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 11</span>
                    <h3 class="chap-title">The First Step</h3>
                    <p class="chap-teaser">Rohit rebuilds his exterior habits and rides into Saanvi's quiet street, analyzing the physical boundaries of a looming confrontation.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 12</span>
                    <h3 class="chap-title">The Door Between Us</h3>
                    <p class="chap-teaser">A crisp white shirt and a ticking wall clock. Rohit openly states his long-term intentions to a rigid, calculating household.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 13</span>
                    <h3 class="chap-title">The Space Between Words</h3>
                    <p class="chap-teaser">Listening from behind kitchen frames, Saanvi feels long-standing fears ease as Rohit handles her father's doubts without defensive pride.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 14</span>
                    <h3 class="chap-title">The First "No"</h3>
                    <p class="chap-teaser">The inevitable refusal drops with heavy, flat certainty. A single shared gaze carries an unspoken resolution to survive the decision.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 15</span>
                    <h3 class="chap-title">The Main He Wanted to Be</h3>
                    <p class="chap-teaser">Rohit converts rejection into fuel, focusing completely on long-term discipline while Saanvi faces historical match books at home.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 16</span>
                    <h3 class="chap-title">Knocking on Closed Doors</h3>
                    <p class="chap-teaser">Twelve rejections pass over a grueling timeline. News breaks of a fixed marriage, forcing Rohit to stand profoundly still in time.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 17</span>
                    <h3 class="chap-title">The Day She Left</h3>
                    <p class="chap-teaser">A morning rain outlines a wedding far away. Rohit learns to live without chasing oxygen, burying his old campus persona deep.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 18</span>
                    <h3 class="chap-title">The Quiet Years</h3>
                    <p class="chap-teaser">Eight solitary years unfold inside a small private school in Hyderabad until a casual knock regarding student admissions changes reality.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 19</span>
                    <h3 class="chap-title">Fate Steps In (Revised Casual Flow)</h3>
                    <p class="chap-teaser">Saanvi stands at a school counter alongside her son, Aarav. A conversation details a shattered past and an open, unexpected re-entry.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 20</span>
                    <h3 class="chap-title">Threads Rewoven</h3>
                    <p class="chap-teaser">Brief school-gate greetings transform back into deep familiarity, proving that some structural alignments are safe from time.</p>
                </div>
                <div class="chapter-card">
                    <span class="chap-num">Chapter 21</span>
                    <h3 class="chap-title">Knocking Again</h3>
                    <p class="chap-teaser">Rohit approaches the white gate once more. Facing older, altered eyes, he requests a final chance to construct their true home.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 5 — QUOTES SECTION -->
    <section id="quotes" class="quotes-section section-offset">
        <div class="container">
            <span class="section-label">Selected Dialogue & Prose</span>
            <h2 class="section-heading">The Text of Silence</h2>
            <div class="quotes-wrapper">
                <div class="featured-quote-block">
                    <p class="main-quote-text">“I'm not going to propose to her... Because if she's already mine in her heart, I don't need to force words. And I won't scare her with marriage before she's ready.”</p>
                    <span class="main-quote-context">Rohit to Meera — Chapter 2</span>
                </div>
                <div class="quotes-subgrid">
                    <div class="quote-card">
                        <p class="quote-card-text">“I want us to live together in the same house even after marriage. We always said that, na?”</p>
                        <span class="quote-card-context">Saanvi's Terrace Dream — Chapter 2</span>
                    </div>
                    <div class="quote-card">
                        <p class="quote-card-text">“Because when I looked away every time he walked into the room, it wasn't because I disliked him—it was because I didn't know how to hide how much I didn't.”</p>
                        <span class="quote-card-context">Saanvi's Reflection — Chapter 8</span>
                    </div>
                    <div class="quote-card">
                        <p class="quote-card-text">“The boy who used to chase love like it was oxygen had now decided to live without breathing it.”</p>
                        <span class="quote-card-context">Narrative — Chapter 17</span>
                    </div>
                    <div class="quote-card">
                        <p class="quote-card-text">“It's strange, isn't it? How after all this time, some people still feel... familiar.”</p>
                        <span class="quote-card-context">Saanvi at School — Chapter 20</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 6 — JOURNEY / TIMELINE SECTION -->
    <section id="journey" class="journey-section section-offset">
        <div class="container">
            <span class="section-label">The Chronicle</span>
            <h2 class="section-heading">Steps Across a Decade</h2>
            <div class="timeline">
                
                <div class="timeline-block timeline-block-left">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Introduction</span>
                        <h4 class="timeline-title">The Living Room Shift</h4>
                        <p class="timeline-desc">Saanvi retreats from Rohit's presence instantly, initializing a dynamic defined by defensive distances and a deep grammar of quiet observations.</p>
                    </div>
                </div>

                <div class="timeline-block timeline-block-right">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Alliance</span>
                        <h4 class="timeline-title">The Overheard Blueprint</h4>
                        <p class="timeline-desc">Rohit overhears Saanvi's dream of maintaining an eternal home with Meera, transforming his romantic intent into a lifelong protective vow.</p>
                    </div>
                </div>

                <div class="timeline-block timeline-block-left">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Barrier</span>
                        <h4 class="timeline-title">The Social Divide</h4>
                        <p class="timeline-desc">The reality of OC/BC caste limits sets in. Rohit adopts rigorous external discipline to counter malicious campus rumors and prove his foundational substance.</p>
                    </div>
                </div>

                <div class="timeline-block timeline-block-right">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Crisis</span>
                        <h4 class="timeline-title">Twelve Doors Refused</h4>
                        <p class="timeline-desc">Rohit confronts Saanvi's father honestly, facing a series of traditional rejections that conclude with Saanvi's arranged departure to another town.</p>
                    </div>
                </div>

                <div class="timeline-block timeline-block-left">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Interim</span>
                        <h4 class="timeline-title">Eight Solitary Years</h4>
                        <p class="timeline-desc">Time moves forward evenly. Rohit leads a quiet life teaching in Hyderabad, safely guarding an old narrative while his close peers move across the world.</p>
                    </div>
                </div>

                <div class="timeline-block timeline-block-right">
                    <div class="timeline-marker"></div>
                    <div class="timeline-item">
                        <span class="timeline-stage">The Convergence</span>
                        <h4 class="timeline-title">The Classroom Encounter</h4>
                        <p class="timeline-desc">Saanvi walks back into Rohit's school seeking admissions for her young son, ending the long winter with familiar smiles and a final walk towards the white gate.</p>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- SECTION 7 — ENDING SECTION -->
    <section class="ending-section">
        <div class="container">
            <div class="ending-container">
                <span class="ending-label">The Resolution</span>
                <h2 class="ending-heading">Beyond the Unspoken</h2>
                <p class="ending-message">
                    Some stories refuse to spark with immediate fireworks; they are structured from long pauses, heavy rainfall, and years of intentional waiting. Tested Hearts 2 ends not with an erratic declaration, but with a steady step toward an older door—proving that when the surrounding world finally shifts, real love stands prepared to build what was promised in the quiet.
                </p>
                <div class="ending-quote-box">
                    <p class="ending-quote">“You should talk to her,” he said at last. “If she feels the same... we'll think about it.”</p>
                    <p class="ending-reflection">The Final Threshold — Chapter 21</p>
                </div>
            </div>
        </div>
    </section>

    <!-- SECTION 8 — FOOTER -->
    <footer class="footer">
        <div class="container">
            <h3 class="footer-title">TESTED HEARTS 2</h3>
            <p class="footer-author">A Novel of Contemporary Devotion</p>
            <p class="footer-quote">“Some people were never meant to be strangers.”</p>
        </div>
    </footer>

    <!-- TECHNICAL JAVASCRIPT FOR INTERACTIVE USER EXPERIENCE -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const sections = document.querySelectorAll('.section-offset, .hero');
            const navLinks = document.querySelectorAll('.nav-route');
            const navbar = document.getElementById('navbar');

            // Scroll Spying Functionality
            window.addEventListener('scroll', () => {
                let current = '';
                
                if (window.scrollY > 50) {
                    navbar.style.boxShadow = '0 10px 30px rgba(44, 37, 32, 0.04)';
                    navbar.style.backgroundColor = 'rgba(251, 249, 245, 0.95)';
                } else {
                    navbar.style.boxShadow = 'none';
                    navbar.style.backgroundColor = 'rgba(251, 249, 245, 0.85)';
                }

                sections.forEach(section => {
                    const sectionTop = section.offsetTop;
                    const sectionHeight = section.clientHeight;
                    if (window.scrollY >= (sectionTop - 120)) {
                        current = section.getAttribute('id');
                    }
                });

                navLinks.forEach(link => {
                    link.classList.remove('active');
                    if (current && link.getAttribute('href').includes(current)) {
                        link.classList.add('active');
                    }
                });
            });

            // Smooth Contextual Click Adjustment
            navLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = link.getAttribute('href');
                    if(targetId === '#') return;
                    
                    const targetSection = document.querySelector(targetId);
                    if (targetSection) {
                        const topPosition = targetSection.offsetTop - 60;
                        window.scrollTo({
                            top: topPosition,
                            behavior: 'smooth'
                        });
                    }
                });
            });
        });
    </script>
    <%- include('partials/footer') %>