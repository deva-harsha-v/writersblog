<%- include('partials/header') %>

  <!-- ═══════════════ HERO SECTION ═══════════════ -->
  <section class="hero">
    <!-- Giant background name -->
    <h1 class="hero-bg-name" aria-hidden="true">DEVA HARSHA</h1>

    <!-- Foreground photo -->
    <div class="hero-photo-wrap">
      <img src="/images/mine_.png" alt="Deva Harsha Veerla" class="hero-photo" />
    </div>

    <!-- Left tags block -->
    <div class="hero-tags-block">
      <span>[ WRITER ]</span>
      <span>[ DIRECTOR ]</span>
    </div>

    <!-- Right bio block -->
    <div class="hero-bio-block">
      <p class="hero-tagline">[ &nbsp; STORIES THAT STAY WITH YOU &nbsp; ]</p>
      <p class="hero-bio-text">
        Writing, for me, is a way to explore the beauty and chaos of being human. Through every story, I aim to create worlds that readers can see themselves in — <mark>stories that move</mark>, challenge, and heal.
      </p>
      <a href="/works" class="btn btn-dark">Explore My Works</a>
    </div>

    <!-- Bottom left upcoming -->
    <div class="hero-upcoming">
      <span class="upcoming-label">UPCOMING BOOK &nbsp; ↗</span>
      <strong class="upcoming-title">THE DEEP END</strong>
    </div>
  </section>

  <!-- ═══════════════ POPULAR WORKS COMPONENT ═══════════════ -->
  <section class="featured-works">
      <div class="container">

          <div class="section-header">
              <span class="section-tag">MY STORIES</span>
              <h2>Popular Works</h2>
              <p>
                  Stories exploring obsession, love, horror, mystery and the
                  fragile nature of humanity.
              </p>
          </div>

          <div class="works-grid">

              <div class="work-card">
                  <img src="/images/thepreservationist.png" alt="The Preservationist">
                  <div class="work-content">
                      <span class="genre">Psychological Thriller</span>
                      <h3>The Preservationist</h3>
                      <p>
                          A chilling tale of a man who believes beauty should be
                          preserved forever, no matter the cost.
                      </p>
                  </div>
              </div>

              <div class="work-card">
                  <img src="/images/whispersinthedark.png" alt="Whispers in the Dark">
                  <div class="work-content">
                      <span class="genre">Horror Mystery</span>
                      <h3>Whispers in the Dark</h3>
                      <p>
                          Strange voices emerge from the darkness, leading a
                          young man toward a terrifying truth.
                      </p>
                  </div>
              </div>

              <div class="work-card">
                  <img src="/images/testedhearts.png" alt="Tested Hearts">
                  <div class="work-content">
                      <span class="genre">Romance Drama</span>
                      <h3>Tested Hearts</h3>
                      <p>
                          Love tested by time, distance, sacrifice and destiny.
                      </p>
                  </div>
              </div>
          </div>

          <div class="works-btn">
              <a href="/works" class="btn btn-dark">
                  View All Works
              </a>
          </div>

      </div>
  </section>

  

<%- include('partials/footer') %>