<%- include('partials/header') %>
<link rel="stylesheet" href="/css/preservationist.css">
<header id="site-header">
        <div class="nav-container">
            <a class="logo serif-title">THE PRESERVATIONIST</a>
            <nav>
                <ul>
                    <li><a href="#story" class="nav-link">Story</a></li>
                    <li><a href="#characters" class="nav-link">Characters</a></li>
                    <li><a href="#chapters" class="nav-link">Chapters</a></li>
                    <li><a href="#quotes" class="nav-link">Quotes</a></li>
                    <li><a href="#journey" class="nav-link">Journey</a></li>
                </ul>
            </nav>
        </div>
    </header>

    <section id="hero">
        <div class="hero-grid">
            <div class="hero-title-group">
                <span class="section-label">A Psychological Thriller</span>
                <h1 class="serif-title">The Preservationist</h1>
                <div class="hero-author">Deva Harsha V</div>
                <div class="hero-tagline">“He doesn't kill them. He keeps them.”</div>
                <p class="hero-hook">When a string of flawless disappearances leaves an indifferent police department behind, a true-crime podcaster uncovers a pattern pointing to a shuttered facility—and an obsession designed to freeze time forever.</p>
            </div>
            <div class="book-cover-container">
                <div class="poster-frame">
                    <img src="https://cdn-gcs.inkitt.com/vertical_storycovers/bd12c3cf11c98ddbb9fd1e564590a5eb.jpg" alt="The Preservationist Poster" class="poster-img">
                </div>
            </div>
        </div>
        <div class="scroll-indicator">
            <span>Scroll to Enter</span>
            <div class="mouse"></div>
        </div>
    </section>

    <section id="story">
        <div class="story-header">
            <span class="section-label">The Concept</span>
            <h2 class="serif-title">The Blueprint of Silence</h2>
        </div>
        <div class="story-grid">
            <div class="story-left">
                <div class="story-highlight-quote">
                    “They didn't disappear. They were taken. Smooth. Silent. Like it had never been there.”
                </div>
                <div class="story-synopsis">
                    <p>Dev, host of the true-crime podcast <em>Unfinished Stories</em>, refuses to dismiss the unexplained disappearances of three young urban independent women as simple coincidences. Charting their last known locations across the city grid, he watches them converge onto an abandoned industrial outskirts: the sprawling, mysterious campus of Voss Pharmaceuticals.</p>
                    <p>Drawn into an investigation that escalates far beyond standard investigative journalism, Dev forms an ad-hoc alliance of deep-web investigators and analytical minds. Together, they infiltrate the facility and uncover a horrifying technological breakthrough: Elara, a compound that scales down metabolic activity to near zero while maintaining fully functional neurological networks inside unchanged, unaging physical bodies.</p>
                </div>
                <div class="theme-container">
                    <div class="theme-title">Core Themes Explored</div>
                    <div class="theme-tags">
                        <span class="theme-tag">The Peril of Control</span>
                        <span class="theme-tag">Time As Destruction</span>
                        <span class="theme-tag">Grief Subverted</span>
                        <span class="theme-tag">The Horror of Awareness</span>
                    </div>
                </div>
            </div>
            <div class="story-right">
                <div class="stats-grid">
                    <div class="stat-card">
                        <span class="stat-num">16</span>
                        <span class="stat-label">Chapters Analyzed</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num">5</span>
                        <span class="stat-label">Main Investigators</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num">3</span>
                        <span class="stat-label">Original Subjects</span>
                    </div>
                    <div class="stat-card">
                        <span class="stat-num">0</span>
                        <span class="stat-label">Signs of Escape</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="characters">
        <div class="section-header">
            <span class="section-label">The Dramatis Personae</span>
            <h2 class="serif-title">Minds in the Architecture</h2>
        </div>
        <div class="characters-grid">
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Dev</h3>
                    <span class="char-role">The Obsessive Narrator</span>
                </div>
                <p class="char-desc">A deep true-crime podcaster hosting "Unfinished Stories". He is driven by structural patterns, refusing to let unexplained dismissals by local authorities clear clean exits from memory.</p>
                <div class="char-traits">
                    <span class="char-trait">Observant</span>
                    <span class="char-trait">Persistent</span>
                    <span class="char-trait">Reactive</span>
                </div>
            </div>
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Riya Sharma</h3>
                    <span class="char-role">The Analytical Catalyst</span>
                </div>
                <p class="char-desc">A rigorous journalism student who looks beyond where subjects disappear to trace exactly why they felt no immediate fear. She possesses an obsession that forces deep psychological balance with the curator.</p>
                <div class="char-traits">
                    <span class="char-trait">Unafraid</span>
                    <span class="char-trait">Depth-Driven</span>
                    <span class="char-trait">Persistent</span>
                </div>
            </div>
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Dr. Aryan Voss</h3>
                    <span class="char-role">The Curator</span>
                </div>
                <p class="char-desc">A brilliant medical designer convinced that time is the true killer of admirable targets. He operates under self-assigned absolute logic to save presence from physical decay.</p>
                <div class="char-traits">
                    <span class="char-trait">Unflinching</span>
                    <span class="char-trait">Consistent</span>
                    <span class="char-trait">Controlled</span>
                </div>
            </div>
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Neha Iyer</h3>
                    <span class="char-role">The Technical Eye</span>
                </div>
                <p class="char-desc">A precise researcher tasked with isolating unknown compounds. Her biological verification forces the group to realize suspension isolates active minds between life and death.</p>
                <div class="char-traits">
                    <span class="char-trait">Structured</span>
                    <span class="char-trait">Precise</span>
                    <span class="char-trait">Consequence-Aware</span>
                </div>
            </div>
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Kabir Mehta</h3>
                    <span class="char-role">The System Intruder</span>
                </div>
                <p class="char-desc">A specialized analyst capable of hacking traffic architectures and deep encrypted partitions, breaking obsolete corporate firewalls to reveal hidden personal truths.</p>
                <div class="char-traits">
                    <span class="char-trait">Technical</span>
                    <span class="char-trait">Curious</span>
                    <span class="char-trait">Uncoordinated</span>
                </div>
            </div>
            <div class="character-card">
                <div class="char-meta">
                    <h3 class="char-name serif-title">Zara Khan</h3>
                    <span class="char-role">The Human Warning</span>
                </div>
                <p class="char-desc">The investigator who initially identifies the clean white vehicle on street grids. She remains intensely aware of monitoring, seeking safety and emotional distance over clinical metrics.</p>
                <div class="char-traits">
                    <span class="char-trait">Fear-Aware</span>
                    <span class="char-trait">Protective</span>
                    <span class="char-trait">Vigilant</span>
                </div>
            </div>
        </div>
    </section>

    <section id="chapters">
        <div class="section-header">
            <span class="section-label">The Breakdown</span>
            <h2 class="serif-title">Chronology of Suspended Animation</h2>
        </div>
        <div class="chapters-grid">
            <div class="chapter-card">
                <span class="chap-num">Chapter 1</span>
                <h3 class="chap-title serif-title">The Missing Pattern</h3>
                <p class="chap-teaser">Dev breaks past lazy police explanations to lock onto three smiling faces and trace coordinates toward a forgotten industrial edge.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 2</span>
                <h3 class="chap-title serif-title">Voices That Shouldn't Exist</h3>
                <p class="chap-teaser">An unpolished true-crime broadcast triggers an unorganic spike in attention, delivering a precise, single anonymous nudge: *They're not gone.*</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 3</span>
                <h3 class="chap-title serif-title">The Voss Campus</h3>
                <p class="chap-teaser">Five investigators step past a rusted main gate onto clean, weedless asphalt where active building ventilation systems hum in secret.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 4</span>
                <h3 class="chap-title serif-title">Elara</h3>
                <p class="chap-teaser">Microscopic evaluation of a glowing solution reveals cell structures held in absolute stasis—alive, unmutating, and completely frozen.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 5</span>
                <h3 class="chap-title serif-title">The Curator</h3>
                <p class="chap-teaser">Deep beneath official blueprints, Dr. Aryan Voss calibrates structural metrics inside an underground gallery of glass chambers.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 6</span>
                <h3 class="chap-title serif-title">Cracks in the Group</h3>
                <p class="chap-teaser">A fragmented group thread exposes divergent intentions as a clean, white unmarked vehicle parks silently outside a window.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 7</span>
                <h3 class="chap-title serif-title">The Fourth Presence</h3>
                <p class="chap-teaser">The team infiltrates the hidden gallery and watches a locked human eye shift within the golden liquid to track their presence.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 8</span>
                <h3 class="chap-title serif-title">The Interruption</h3>
                <p class="chap-teaser">Lights drop out completely before Voss isolates the group, presenting an absolute statement: *Choice accelerates decay.*</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 8</span>
                <h3 class="chap-title serif-title">The First Loss</h3>
                <p class="chap-teaser">As the team attempts to retreat, a sweet vapor leaks through the veins of the system, capturing a vital mind inside total physical deceleration.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 10</span>
                <h3 class="chap-title serif-title">The Journal</h3>
                <p class="chap-teaser">Deep core archives expose the raw journal of a younger son watching his mother disappear long before his system took selection form.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 11</span>
                <h3 class="chap-title serif-title">The Real Choice</h3>
                <p class="chap-teaser">Voss tracks his missing compound straight to the group's room, stepping inside to re-evaluate the ultimate value of presence.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 12</span>
                <h3 class="chap-title serif-title">Breaking Reality</h3>
                <p class="chap-teaser">With Neha trapped, the team maps an unverified gamble to return to the facility and execute chemical destabilization.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 13</span>
                <h3 class="chap-title serif-title">The Gallery Shatters</h3>
                <p class="chap-teaser">Glass fractures cross the chambers, pooling fluid across the floor as raw reality returns to confront a panicking curator.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 14</span>
                <h3 class="chap-title serif-title">Fracture</h3>
                <p class="chap-teaser">Alarms cascade across the collapsing level. Dev evacuates the survivors while Riya chooses to remain alone at the threshold.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 15</span>
                <h3 class="chap-title serif-title">The Truth Room</h3>
                <p class="chap-teaser">An unmaintained workstation reveals early historical doubts before authorities enter to claim a compliant, unmoving architect.</p>
            </div>
            <div class="chapter-card">
                <span class="chap-num">Chapter 16</span>
                <h3 class="chap-title serif-title">The Unsettling Aftermath</h3>
                <p class="chap-teaser">Official narratives seal the records, leaving the investigators to process persistent internal echoes of absolute stillness.</p>
            </div>
        </div>
    </section>

    <section id="quotes">
        <div class="section-header">
            <span class="section-label">Fragments of Logic</span>
            <h2 class="serif-title">Echoes Inside the Mind</h2>
        </div>
        <div class="featured-quote-container">
            <div class="featured-quote">“The world destroys what it admires. Decay is not an event. It is a process. And processes can be interrupted.”</div>
            <div class="featured-quote-author">Dr. Aryan Voss</div>
        </div>
        <div class="quotes-grid">
            <div class="quote-card">
                <p class="quote-text">“Imagine your body stops moving. Your heart slows. Your breathing almost disappears. But your brain... Your brain is still active.”</p>
                <span class="quote-context">Neha Iyer — Chapter 4</span>
            </div>
            <div class="quote-card">
                <p class="quote-text">“You measure harm in endings. I measure it in loss. Choice accelerates decay. It is consistent.”</p>
                <span class="quote-context">Dr. Aryan Voss — Chapter 8</span>
            </div>
            <div class="quote-card">
                <p class="quote-text">“Stopping is the only way to protect. She hated that part of her that paused at that line. That considered it. Even for a second.”</p>
                <span class="quote-context">Riya Sharma — Chapter 16</span>
            </div>
            <div class="quote-card">
                <p class="quote-text">“I was safe there. Because in her mind—stillness had been peace. No pain. No change. No loss. And that—was the most dangerous idea of all.”</p>
                <span class="quote-context">The Survivor — Chapter 16</span>
            </div>
        </div>
    </section>

    <section id="journey">
        <div class="section-header">
            <span class="section-label">The Progression</span>
            <h2 class="serif-title">The Disruption of Architecture</h2>
        </div>
        <div class="timeline-container">
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-stage">The Convergence</span>
                    <h3 class="timeline-title serif-title">Isolation of the Urban Pattern</h3>
                    <p class="timeline-desc">Dev isolates three clean disappearances across distinct urban zones, discovering their linear alignments map directly to a closed corporate perimeter outside city limits.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-stage">The Infiltration</span>
                    <h3 class="timeline-title serif-title">Trespassing and Material Theft</h3>
                    <p class="timeline-desc">The five-member team enters the unlooted, maintained environment of Voss Pharmaceuticals, accidentally tracking and securing a sealed vial containing a glowing, unclassified compound.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-stage">The Discovery</span>
                    <h3 class="timeline-title serif-title">Consciousness Behind the Glass</h3>
                    <p class="timeline-desc">Re-entering the facility, the team gains entrance to the rows of tall golden chambers, discovering suspended human subjects who track them with active, desperate eyes from inside the solution.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-stage">The Retaliation</span>
                    <h3 class="timeline-title serif-title">The Suppression of Neha</h3>
                    <p class="timeline-desc">Voss isolates the group in reinforced glass panel structures. During their desperate escape, an industrial release of Elara forces Neha into absolute physical stillness while her mind remains aware.</p>
                </div>
            </div>
            <div class="timeline-item">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <span class="timeline-stage">The Demolition</span>
                    <h3 class="timeline-title serif-title">The Collapse of Imperfect Stasis</h3>
                    <p class="timeline-desc">Returning with chemical destabilizers, Kabir forces system overrides. The glass walls shatter violently, flooding reality, change, and decay back into the room as Voss loses his belief.</p>
                </div>
            </div>
        </div>
    </section>

    <section id="ending">
        <div class="ending-wrap">
            <span class="section-label">The Final Message</span>
            <div class="ending-quote serif-title">“Is it better to live and lose… or to never lose at all?”</div>
            <p class="ending-message">The underground chambers are permanently sealed, rewritten in municipal records as an illegal occupancy of an abandoned pharmaceutical unit. The architecture is dark, but the idea adapted, waiting in a white cell where a silent curator never stops writing his journal. The true danger is no longer the madness—it is the meaning that remains twisted behind.</p>
            <div class="ending-reflection">The System Never Truly Cleans</div>
        </div>
    </section>

    <footer>
        <div class="footer-content">
            <div class="footer-title">THE PRESERVATIONIST</div>
            <div class="footer-author">DEVA HARSHA V</div>
            <div class="footer-quote">“Normal didn't exist anymore. Because in her mind—stillness had been peace.”</div>
        </div>
    </footer>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const header = document.getElementById('site-header');
            const navLinks = document.querySelectorAll('.nav-link');
            const sections = document.querySelectorAll('section[id]');

            // Scroll effect for Header
            window.addEventListener('scroll', () => {
                if (window.scrollY > 50) {
                    header.style.padding = '0.4rem 2rem';
                    header.style.background = 'rgba(5, 5, 8, 0.95)';
                    header.style.boxShadow = '0 10px 30px rgba(0,0,0,0.5)';
                } else {
                    header.style.padding = '0.6rem 2rem';
                    header.style.background = 'rgba(8, 8, 12, 0.85)';
                    header.style.boxShadow = 'none';
                }

                // Active section highlighting
                let current = '';
                sections.forEach(section => {
                    const sectionTop = section.offsetTop;
                    const sectionHeight = section.clientHeight;
                    if (window.scrollY >= (sectionTop - 200)) {
                        current = section.getAttribute('id');
                    }
                });

                navLinks.forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href').slice(1) === current) {
                        link.classList.add('active');
                    }
                });
            });

            // Smooth scrolling for navigation links
            navLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    const targetId = link.getAttribute('href');
                    const targetSection = document.querySelector(targetId);
                    if (targetSection) {
                        window.scrollTo({
                            top: targetSection.offsetTop - 60,
                            behavior: 'smooth'
                        });
                    }
                });
            });

            // Subtle parallax effect on cover poster inside hero
            const cover = document.querySelector('.poster-frame');
            const hero = document.getElementById('hero');
            if (cover && hero) {
                hero.addEventListener('mousemove', (e) => {
                    const xAxis = (window.innerWidth / 2 - e.pageX) / 40;
                    const yAxis = (window.innerHeight / 2 - e.pageY) / 40;
                    cover.style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
                });

                hero.addEventListener('mouseleave', () => {
                    cover.style.transform = `rotateY(-5deg) rotateX(2deg)`;
                });
            }
        });
    </script>

        <%- include('partials/footer') %>